{
	"project": "1two-api",
	"schema": {
		"variables": {
			"DATABASE_URL": {
				"name": "DATABASE_URL",
				"title": "PostgreSQL connection string",
				"type": "string",
				"required": true,
				"secret": true
			},
			"PORT": {
				"name": "PORT",
				"title": "API server port",
				"type": "number",
				"default": "8090",
				"required": true
			},
			"ALLOWED_ORIGINS": {
				"name": "ALLOWED_ORIGINS",
				"title": "CORS allowed origins (comma-separated)",
				"type": "string",
				"default": "http://localhost:3000",
				"required": true
			},
			"UPLOAD_DIR": {
				"name": "UPLOAD_DIR",
				"title": "File upload directory",
				"type": "string",
				"default": "./uploads",
				"required": true
			},
			"TURNSTILE_SECRET_KEY": {
				"name": "TURNSTILE_SECRET_KEY",
				"title": "Cloudflare Turnstile secret key",
				"type": "string",
				"required": true,
				"secret": true
			},
			"R2_ACCOUNT_ID": {
				"name": "R2_ACCOUNT_ID",
				"title": "Cloudflare account ID for R2",
				"type": "string",
				"required": true
			},
			"R2_ACCESS_KEY_ID": {
				"name": "R2_ACCESS_KEY_ID",
				"title": "R2 S3-compatible access key ID",
				"type": "string",
				"required": true,
				"secret": true
			},
			"R2_SECRET_ACCESS_KEY": {
				"name": "R2_SECRET_ACCESS_KEY",
				"title": "R2 S3-compatible secret access key",
				"type": "string",
				"required": true,
				"secret": true
			},
			"R2_BUCKET_NAME": {
				"name": "R2_BUCKET_NAME",
				"title": "R2 bucket name",
				"type": "string",
				"default": "1two-files",
				"required": true
			},
			"INTERNAL_SECRET": {
				"name": "INTERNAL_SECRET",
				"title": "Secret for internal API calls (cron cleanup)",
				"type": "string",
				"required": true,
				"secret": true
			},
			"CLOUDFLARE_ACCOUNT_ID": {
				"name": "CLOUDFLARE_ACCOUNT_ID",
				"title": "Cloudflare account ID for Browser Rendering crawl API",
				"type": "string",
				"required": true
			},
			"CLOUDFLARE_API_TOKEN": {
				"name": "CLOUDFLARE_API_TOKEN",
				"title": "Cloudflare API token for Browser Rendering",
				"type": "string",
				"required": true,
				"secret": true
			},
			"LLM_API_KEY": {
				"name": "LLM_API_KEY",
				"title": "API key for llms.txt LLM provider (Moonshot/Kimi K2)",
				"type": "string",
				"required": true,
				"secret": true
			},
			"LLM_PROVIDER": {
				"name": "LLM_PROVIDER",
				"title": "LLM provider type (openai or anthropic)",
				"type": "string",
				"default": "openai",
				"required": false
			},
			"LLM_BASE_URL": {
				"name": "LLM_BASE_URL",
				"title": "Base URL for OpenAI-compatible LLM API",
				"type": "string",
				"default": "https://api.moonshot.ai/v1",
				"required": false
			},
			"LLM_MODEL": {
				"name": "LLM_MODEL",
				"title": "LLM model ID",
				"type": "string",
				"default": "kimi-k2-0711",
				"required": false
			},
			"POLAR_ACCESS_TOKEN": {
				"name": "POLAR_ACCESS_TOKEN",
				"title": "Polar API access token",
				"type": "string",
				"required": true,
				"secret": true
			},
			"POLAR_WEBHOOK_SECRET": {
				"name": "POLAR_WEBHOOK_SECRET",
				"title": "Polar webhook signing secret",
				"type": "string",
				"required": true,
				"secret": true
			},
			"POLAR_ORGANIZATION_ID": {
				"name": "POLAR_ORGANIZATION_ID",
				"title": "Polar organization ID",
				"type": "string",
				"required": true
			},
			"POLAR_ENVIRONMENT": {
				"name": "POLAR_ENVIRONMENT",
				"title": "Polar environment (sandbox or production)",
				"type": "string",
				"default": "sandbox",
				"required": false
			},
			"POLAR_PRO_PRODUCT_ID": {
				"name": "POLAR_PRO_PRODUCT_ID",
				"title": "Polar Pro plan product ID",
				"type": "string",
				"required": true
			},
			"POLAR_MAX_PRODUCT_ID": {
				"name": "POLAR_MAX_PRODUCT_ID",
				"title": "Polar Max plan product ID",
				"type": "string",
				"required": true
			},
			"NEON_API_KEY": {
				"name": "NEON_API_KEY",
				"title": "Neon API key for managed database provisioning",
				"type": "string",
				"required": true,
				"secret": true
			},
			"NEON_ORG_ID": {
				"name": "NEON_ORG_ID",
				"title": "Neon organization ID",
				"type": "string",
				"required": true
			},
			"TURSO_API_TOKEN": {
				"name": "TURSO_API_TOKEN",
				"title": "Turso Platform API token for hosted SQLite",
				"type": "string",
				"required": true,
				"secret": true
			},
			"TURSO_ORG_SLUG": {
				"name": "TURSO_ORG_SLUG",
				"title": "Turso organization slug",
				"type": "string",
				"required": true
			},
			"TURSO_GROUP": {
				"name": "TURSO_GROUP",
				"title": "Turso database group",
				"type": "string",
				"default": "default",
				"required": false
			}
		}
	},
	"environments": {
		"development": {
			"sheets": [".env.api.development"]
		},
		"production": {
			"sheets": [".env.api.production"]
		}
	},
	"origins": {
		"cloudflare": {
			"type": "cloudflare",
			"mode": "individual",
			"worker": "onetwo-api"
		}
	}
}
