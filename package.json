{
  "name": "1tt-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter ./apps/web dev",
    "dev:web": "bun run --filter ./apps/web dev",
    "dev:kim": "bun run --filter ./apps/kim dev",
    "dev:api": "ee apply development -c .ee.api -- go run ./api/cmd/server",
    "mobile:start": "bun run --filter ./apps/kim-mobile start",
    "mobile:ios": "bun run --filter ./apps/kim-mobile ios",
    "mobile:android": "bun run --filter ./apps/kim-mobile android",
    "build:web": "bun run --filter ./apps/web build",
    "build:kim": "bun run --filter ./apps/kim build",
    "lint": "bun run --filter './apps/*' lint",
    "test": "bun run --filter ./apps/web test",
    "test:e2e": "bun run --filter ./apps/web test:e2e",
    "cf:deploy:web": "bun run --filter ./apps/web cf:deploy",
    "cf:deploy:kim": "bun run --filter ./apps/kim cf:deploy",
    "cf:deploy:api": "cd workers/api-container && wrangler deploy"
  },
  "devDependencies": {
    "@1tt/kim": "./apps/kim",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@1tt/kim": "workspace:*",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "jszip": "^3.10.1",
    "react-i18next": "^17.0.3"
  },
}
