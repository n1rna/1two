# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# generated
/public/sitemap.xml

# next.js
/.next/
/out/

# cloudflare
/.open-next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# ee configs (schemas + environments) should be tracked
!.ee.*

# uploaded files
/uploads
/api/uploads

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
api/server

# planning docs
TOOL_IDEAS.md

# wrangler tail debug captures
workers/api-container/tail.out
workers/api-container/tail.err
