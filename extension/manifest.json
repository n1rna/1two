{
  "manifest_version": 3,
  "name": "1tt.dev Tools",
  "version": "1.0.0",
  "description": "Quick access to 1tt.dev developer tools from your address bar",
  "permissions": ["omnibox", "tabs"],
  "omnibox": {
    "keyword": "1t"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
